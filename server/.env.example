PORT=8000
CLIENT_URL=http://localhost:5173
MONGO_URI=

# --- LLM (Groq — free tier: https://console.groq.com) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
TAVILY_API_KEY=
LOG_LEVEL=debug
LOG_TEXT_LIMIT=600
LOG_OBJECT_LIMIT=2500
