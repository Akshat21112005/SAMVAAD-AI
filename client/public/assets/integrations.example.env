# Copy relevant lines into client `.env` (VITE_*) and server `.env` (no prefix).
# This file is a template only — do not commit real secrets.

# --- Server: Groq + LangChain (required for AI features) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# DSA code runs on the API server (Node + Python + optional g++/JDK). No remote judge.
# SAMVAAD_PYTHON=python3

# HR / general interviews: optional looping video (MP4/WebM)
# Place file at: client/Interview_agent/public/assets/interview-panel.mp4

# --- Client: Firebase (existing auth) ---
# VITE_FIREBASE_API_KEY=

# --- Optional: real-time video (Daily, Agora, LiveKit, etc.) ---
# VITE_VIDEO_PROVIDER=daily
# VITE_DAILY_ROOM_URL=
# VITE_AGORA_APP_ID=
# VITE_AGORA_TOKEN=

# --- Optional: cloud speech-to-text (Web Speech API needs no key in the browser) ---
# VITE_DEEPGRAM_API_KEY=
